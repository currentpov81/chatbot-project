# ─── Bot ───────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── Database ──────────────────────────────────────────
# Railway PostgreSQL example:
DATABASE_URL=postgresql+asyncpg://postgres:password@host:5432/railway

# ─── Redis ─────────────────────────────────────────────
# Railway Redis example:
REDIS_URL=redis://default:password@host:6379

# ─── Settings ──────────────────────────────────────────
MATCH_TIMEOUT=30
